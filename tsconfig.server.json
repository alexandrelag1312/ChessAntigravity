{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist-server",
        "rootDir": "./server",
        "types": [
            "node"
        ],
        "verbatimModuleSyntax": false
    },
    "include": [
        "server/**/*.ts"
    ]
}